// Change the version number (e.g., v1, v2) every time you update your code/CSS
const CACHE_NAME = 'ai-tracker-v1.8';

// List all the static files you want to work offline
const ASSETS_TO_CACHE = [
  './',
  './index.html',
  './manifest.json',
  './icons/rupee.png',
  'https://cdn.tailwindcss.com'
];

// 1. Install Event: Saves the 'App Shell' to the phone's storage
self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open(CACHE_NAME).then((cache) => {
      console.log('[Service Worker] Caching App Shell');
      return cache.addAll(ASSETS_TO_CACHE);
    })
  );
  // Force the waiting service worker to become the active service worker
  self.skipWaiting();
});

// 2. Activate Event: Deletes old caches when you update the version number
self.addEventListener('activate', (event) => {
  event.waitUntil(
    caches.keys().then((cacheNames) => {
      return Promise.all(
        cacheNames.map((cache) => {
          if (cache !== CACHE_NAME) {
            console.log('[Service Worker] Clearing Old Cache:', cache);
            return caches.delete(cache);
          }
        })
      );
    })
  );
  return self.clients.claim();
});

// 3. Fetch Event: Serves files from cache for speed, fetches data from network
self.addEventListener('fetch', (event) => {
  // Check if the request is for your Google Apps Script API
  // We want the API to ALWAYS go to the network for fresh data
  if (event.request.url.includes('script.google.com')) {
    event.respondWith(fetch(event.request));
    return;
  }

  // For everything else (HTML, Icons, Tailwind), use Cache First with a Dynamic Fallback
  event.respondWith(
    caches.match(event.request).then((cachedResponse) => {
      // If the file is in the cache, serve it instantly
      if (cachedResponse) {
        return cachedResponse;
      }
      
      // If the file is NOT in the cache, fetch it from the internet...
      return fetch(event.request).then((networkResponse) => {
        // ...and dynamically save a copy to the cache so we have it for next time!
        return caches.open(CACHE_NAME).then((cache) => {
          // Only cache valid responses to prevent caching errors
          if (networkResponse && networkResponse.status === 200) {
            cache.put(event.request, networkResponse.clone());
          }
          return networkResponse;
        });
      }).catch((error) => {
        console.error('[Service Worker] Network request failed:', error);
      });
    })
  );
});
